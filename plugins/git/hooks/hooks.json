{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git push *)",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre-push-verify.sh",
            "timeout": 600
          }
        ]
      }
    ]
  }
}
